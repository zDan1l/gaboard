{
  "permissions": {
    "allow": [
      "mcp__laravel-boost__application-info",
      "mcp__laravel-boost__database-schema",
      "Bash(php artisan *)",
      "Bash(vendor/bin/pint *)",
      "Bash(composer require *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(composer dump-autoload *)",
      "mcp__laravel-boost__database-query",
      "mcp__laravel-boost__last-error",
      "Bash(timeout 3 bash -c \"while ! curl -s http://localhost:8001 > /dev/null; do sleep 0.5; done\")",
      "mcp__laravel-boost__browser-logs"
    ]
  },
  "disabledMcpjsonServers": [
    "laravel-boost"
  ]
}
